{
  "name": "view-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp check && vp run -r test && vp run -r build",
    "dev": "vp run metrics#dev",
    "demo:server": "vp run orders-demo#server",
    "demo:web": "vp run orders-demo#dev",
    "demo:build": "vp run orders-demo#build",
    "test:server:start": "bash scripts/test-server-start.sh",
    "test:server:stop": "bash scripts/test-server-stop.sh",
    "smoke:deployment": "bash scripts/deployment-smoke.sh",
    "smoke:consumer": "bash scripts/external-consumer-smoke.sh",
    "release:gate": "bash scripts/release-gate.sh",
    "soak:10m": "bash scripts/worker-soak-10m.sh",
    "pack:dry-run": "vp run core#build && vp run react#build && vp run testing#build && pnpm --filter @view-server/core pack --dry-run && pnpm --filter @view-server/react pack --dry-run && pnpm --filter @view-server/testing pack --dry-run",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=26.0.0"
  },
  "packageManager": "pnpm@11.0.9",
  "pnpm": {
    "onlyBuiltDependencies": [
      "chdb",
      "msgpackr-extract",
      "protobufjs"
    ]
  }
}

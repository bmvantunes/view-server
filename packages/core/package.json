{
  "name": "@view-server/core",
  "version": "0.0.0",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./client": {
      "types": "./dist/client.d.mts",
      "import": "./dist/client.mjs"
    },
    "./config": {
      "types": "./dist/config.d.mts",
      "import": "./dist/config.mjs"
    },
    "./errors": {
      "types": "./dist/errors.d.mts",
      "import": "./dist/errors.mjs"
    },
    "./kafka": {
      "types": "./dist/kafka.d.mts",
      "import": "./dist/kafka.mjs"
    },
    "./snapshot/chdb": {
      "types": "./dist/snapshot/chdb-backend.d.mts",
      "import": "./dist/snapshot/chdb-backend.mjs"
    },
    "./kafka/platformatic": {
      "types": "./dist/kafka/platformatic-consumer.d.mts",
      "import": "./dist/kafka/platformatic-consumer.mjs"
    },
    "./query": {
      "types": "./dist/query.d.mts",
      "import": "./dist/query.mjs"
    },
    "./rpc": {
      "types": "./dist/rpc.d.mts",
      "import": "./dist/rpc.mjs"
    },
    "./rpc/websocket": {
      "types": "./dist/rpc/websocket.d.mts",
      "import": "./dist/rpc/websocket.mjs"
    },
    "./runtime": {
      "types": "./dist/runtime.d.mts",
      "import": "./dist/runtime.mjs"
    },
    "./snapshot": {
      "types": "./dist/snapshot.d.mts",
      "import": "./dist/snapshot.mjs"
    },
    "./worker/node": {
      "types": "./dist/worker/topic-worker-node-host.d.mts",
      "import": "./dist/worker/topic-worker-node-host.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "bench:ci-smoke": "node --experimental-strip-types bench/ci-smoke.ts",
    "bench:compare": "node --experimental-strip-types bench/ci-smoke.ts",
    "bench:client-delta": "node --experimental-strip-types bench/client-delta.bench.ts",
    "bench:chdb-sql-mirror": "node --experimental-strip-types bench/chdb-sql-mirror.bench.ts",
    "bench:fanout-queue": "node --experimental-strip-types bench/fanout-queue.bench.ts",
    "bench:grouped-aggregation": "node --experimental-strip-types bench/grouped-aggregation.bench.ts",
    "bench:health-sync": "node --experimental-strip-types bench/health-sync.bench.ts",
    "bench:profile": "node --experimental-strip-types bench/benchmark-profile.ts",
    "bench:profiles": "node --experimental-strip-types bench/benchmark-profile.ts --list",
    "bench:kafka-batch": "node --experimental-strip-types bench/kafka-batch.bench.ts",
    "bench:mutation-log": "node --experimental-strip-types bench/mutation-log.bench.ts",
    "bench:query-engine": "node --experimental-strip-types bench/query-engine.bench.ts",
    "bench:refresh-baselines": "node --experimental-strip-types bench/ci-smoke.ts --refresh-baselines",
    "bench:runtime-websocket-soak": "node --experimental-strip-types bench/runtime-websocket-soak.bench.ts",
    "bench:worker-mutation-batch": "node --experimental-strip-types bench/worker-mutation-batch.bench.ts",
    "bench:worker-replay": "node --experimental-strip-types bench/worker-replay.bench.ts",
    "bench:worker-soak": "node --experimental-strip-types bench/worker-soak.bench.ts",
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vitest run --config vitest.config.ts",
    "check": "vp check"
  },
  "dependencies": {
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/platform-node": "catalog:",
    "@effect/sql-clickhouse": "catalog:",
    "@effect/vitest": "catalog:",
    "@platformatic/kafka": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "chdb": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@effect/platform-node": "4.0.0-beta.65",
    "@platformatic/kafka": "2.0.1",
    "chdb": "1.6.0",
    "effect": "4.0.0-beta.65"
  },
  "peerDependenciesMeta": {
    "@effect/platform-node": {
      "optional": true
    },
    "@platformatic/kafka": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=26.0.0"
  }
}

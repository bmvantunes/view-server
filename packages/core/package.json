{
  "name": "@view-server/core",
  "version": "0.0.0",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./dist/client.mjs"
    },
    "./config": {
      "types": "./src/config.ts",
      "import": "./dist/config.mjs"
    },
    "./errors": {
      "types": "./src/errors.ts",
      "import": "./dist/errors.mjs"
    },
    "./kafka": {
      "types": "./src/kafka.ts",
      "import": "./dist/kafka.mjs"
    },
    "./snapshot/chdb": {
      "types": "./src/snapshot/chdb-backend.ts",
      "import": "./dist/snapshot/chdb-backend.mjs"
    },
    "./kafka/platformatic": {
      "types": "./src/kafka/platformatic-consumer.ts",
      "import": "./dist/kafka/platformatic-consumer.mjs"
    },
    "./query": {
      "types": "./src/query.ts",
      "import": "./dist/query.mjs"
    },
    "./rpc": {
      "types": "./src/rpc.ts",
      "import": "./dist/rpc.mjs"
    },
    "./rpc/websocket": {
      "types": "./src/rpc/websocket.ts",
      "import": "./dist/rpc/websocket.mjs"
    },
    "./runtime": {
      "types": "./src/runtime.ts",
      "import": "./dist/runtime.mjs"
    },
    "./snapshot": {
      "types": "./src/snapshot.ts",
      "import": "./dist/snapshot.mjs"
    },
    "./worker/node": {
      "types": "./src/worker/topic-worker-node-host.ts",
      "import": "./dist/worker/topic-worker-node-host.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "bench:ci-smoke": "node --experimental-strip-types bench/ci-smoke.ts",
    "bench:compare": "node --experimental-strip-types bench/ci-smoke.ts",
    "bench:refresh-baselines": "node --experimental-strip-types bench/ci-smoke.ts --refresh-baselines",
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vitest run --config vitest.config.ts",
    "check": "vp check"
  },
  "dependencies": {
    "@effect/platform-node": "catalog:",
    "@effect/sql-clickhouse": "catalog:",
    "@platformatic/kafka": "catalog:",
    "chdb": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.65"
  },
  "engines": {
    "node": ">=26.0.0"
  }
}

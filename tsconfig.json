{
  "$schema": "./node_modules/@effect/language-service/schema.json",
  "compilerOptions": {
    "noEmit": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "plugins": [
      {
        "name": "@effect/language-service",
        "refactors": true,
        "diagnostics": true,
        "diagnosticsName": true,
        "missingDiagnosticNextLine": "error",
        "includeSuggestionsInTsc": true,
        "ignoreEffectWarningsInTscExitCode": false,
        "ignoreEffectErrorsInTscExitCode": false,
        "ignoreEffectSuggestionsInTscExitCode": false,
        "quickinfoEffectParameters": "always",
        "quickinfo": true,
        "quickinfoMaximumLength": -1,
        "extendedKeyDetection": true,
        "completions": true,
        "goto": true,
        "inlays": true,
        "allowedDuplicatedPackages": [],
        "namespaceImportPackages": ["effect"],
        "topLevelNamedReexports": "follow",
        "barrelImportPackages": [],
        "importAliases": {},
        "renames": true,
        "noExternal": false,
        "pipeableMinArgCount": 1,
        "effectFn": ["span", "suggested-span", "inferred-span", "untraced", "no-span"],
        "layerGraphFollowDepth": 10,
        "skipDisabledOptimization": true,
        "diagnosticSeverity": {
          "anyUnknownInErrorContext": "error",
          "duplicatePackage": "error",
          "effectFnImplicitAny": "error",
          "floatingEffect": "error",
          "genericEffectServices": "error",
          "globalConsole": "error",
          "globalConsoleInEffect": "error",
          "importFromBarrel": "error",
          "missingEffectContext": "error",
          "missingEffectError": "error",
          "missingEffectServiceDependency": "error",
          "missingLayerContext": "error",
          "missingReturnYieldStar": "error",
          "missingStarInYieldEffectGen": "error",
          "nonObjectEffectServiceType": "error",
          "outdatedApi": "error",
          "outdatedEffectCodegen": "error",
          "overriddenSchemaConstructor": "error",
          "unsafeEffectTypeAssertion": "error",
          "unsupportedServiceAccessors": "error",
          "asyncFunction": "warning",
          "cryptoRandomUUID": "warning",
          "cryptoRandomUUIDInEffect": "warning",
          "globalDate": "warning",
          "globalDateInEffect": "warning",
          "globalFetch": "warning",
          "globalFetchInEffect": "warning",
          "globalRandom": "warning",
          "globalRandomInEffect": "warning",
          "globalTimers": "warning",
          "globalTimersInEffect": "warning",
          "newPromise": "warning",
          "processEnv": "warning",
          "processEnvInEffect": "warning",
          "strictBooleanExpressions": "warning"
        }
      }
    ]
  },
  "files": [],
  "exclude": ["**/dist/**", "**/coverage/**", "**/.vitest-attachments/**", "**/__screenshots__/**"]
}
